# Google Maps API key - required for hospital search
# Get one at: https://console.cloud.google.com/google/maps-apis/
# Enable: Maps JavaScript API, Places API
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Optional: Enhances weather data (Open-Meteo is used when not set)
# https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# Optional: News headlines for stress context
# https://newsapi.org/
VITE_NEWS_API_KEY=
